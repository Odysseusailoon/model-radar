# ---- X / twitterapi.io ----
TWITTERAPI_KEY=new1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTERAPI_BASE_URL=https://api.twitterapi.io

# ---- LLM (Anthropic SDK via aihubmix Anthropic-compatible gateway) ----
# Use your aihubmix key here; the SDK's base_url is pointed at aihubmix.
ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://aihubmix.com
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# ---- Database (Railway injects this automatically in prod) ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gtm

# ---- Dashboard (HTTP Basic Auth) ----
DASHBOARD_USER=marketing
DASHBOARD_PASSWORD=please-change-me

# ---- Feishu custom-bot webhook (leave empty to disable alerts) ----
FEISHU_WEBHOOK_URL=

# ---- Reserved inbound webhook shared secret ----
WEBHOOK_SECRET=

# ---- Collector behaviour / cost guardrails ----
COLLECT_INTERVAL_MINUTES=10
MAX_TWEETS_PER_CYCLE=300
MAX_PAGES_PER_QUERY=5

# ---- Alert thresholds ----
ALERT_MIN_FOLLOWERS=10000
ALERT_MEGA_FOLLOWERS=100000
ALERT_MIN_CONFIDENCE=0.75

# ---- Bootstrap seeding (optional): seed products table when empty ----
SEED_PRODUCTS_FILE=products.example.json
